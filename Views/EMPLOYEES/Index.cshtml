@model IEnumerable<Git_MVC_PRO.Models.Employees>

@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Employees</h1>

@if (TempData["message"] != null)
{
    <div class="alert alert-success">@TempData["message"]</div>
}

<div class="d-flex justify-content-between mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New</a>

    <!-- Search bar on the right -->
    <form asp-action="Index" method="get" class="form-inline">
        <div class="input-group input-group-sm">
            <input type="text" name="searchString" class="form-control" placeholder="Search Department" value="@ViewBag.SearchString" />
            <div class="input-group-append">
                <button type="submit" class="btn btn-success btn-sm">Search</button>
                <a asp-action="Index" class="btn btn-secondary btn-sm">Reset</a>
            </div>
        </div>
    </form>
</div>

<table class="table table-striped table-hover table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>FirstName</th>
            <th>LastName</th>
            <th>Age</th>
            <th>Email</th>
            <th>Salary</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(char.ToUpper(item.name[0]) + item.name.Substring(1))</td>
                <td>@(char.ToUpper(item.lastname[0]) + item.lastname.Substring(1))</td>
                <td>@item.age</td>
                <td>@(char.ToUpper(item.email[0]) + item.email.Substring(1))</td>
                <td>@item.salary.ToString("C")</td>
                <td>@item.departments?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }

    </tbody>
</table>
