<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TCS Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    <style>
        .login-register {
            display: flex;
            align-items: center;
            font-size: 0.9rem;
        }

            .login-register a {
                color: white;
                text-decoration: none;
                padding: 0.25rem 0.5rem;
                border-radius: 0.25rem;
                transition: background-color 0.2s;
            }

                .login-register a:hover {
                    background-color: rgba(255, 255, 255, 0.2);
                }
       
    </style>
</head>
<body>

    <!-- Topbar -->
    <div id="topbar" class="d-flex align-items-center">
        <div class="d-flex align-items-center">
            <button id="sidebarCollapse">&#9776;</button>
            <div class="topbar-links ms-2">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                <a asp-controller="Departments" asp-action="Index">Departments</a>
                <a asp-controller="Employees" asp-action="Index">Employees</a>
            </div>
        </div>

        <!-- Login/Register Partial on right -->
        <div class="ms-auto d-flex align-items-center login-register">
            <a href="/Identity/Account/Login">Login</a>
            <span class="mx-2">|</span>
            <a href="/Identity/Account/Register">Register</a>
        </div>

    </div>

    <!-- Sidebar -->
    <nav id="sidebar">
        <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link active" asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Departments" asp-action="Index">Departments</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Employees" asp-action="Index">Employees</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
        </ul>
    </nav>

    <!-- Page Content -->
    <div id="content">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="border-top text-muted">
            &copy; 2026 - TCS Dashboard
        </footer>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $('#sidebarCollapse').on('click', function () {
            $('#sidebar').toggleClass('collapsed');
            $('#content').toggleClass('full');
            $('footer').toggleClass('full');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>