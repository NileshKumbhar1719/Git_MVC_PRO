@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: #f4f7fc;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, sans-serif;
        margin: 0;
    }

    .register-container {
        width: 100%;
        max-width: 480px; /* smaller, compact width */
        background: white;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        overflow: hidden;
        padding: 30px; /* compact padding */
    }

    .register-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .register-header h2 {
            font-size: 1.5rem;
            font-weight: 600;
            margin: 0;
        }

        .register-header p {
            font-size: 0.9rem;
            margin-top: 8px;
            line-height: 1.4;
        }

    .form-control {
        border-radius: 6px;
        padding: 8px 10px;
    }

    .btn-register {
        background: #6ea8fe;
        border: none;
        font-weight: 500;
        padding: 10px 0;
        font-size: 0.95rem;
        transition: background 0.3s ease;
    }

        .btn-register:hover {
            background: #4f8df5;
        }

    .extra-links {
        text-align: center;
        font-size: 0.85rem;
        margin-top: 15px;
    }

        .extra-links a {
            text-decoration: none;
            color: #6ea8fe;
        }

            .extra-links a:hover {
                text-decoration: underline;
            }
</style>

<div class="register-container">

    <div class="register-header">
        <h2>Create Account ✨</h2>
        <p>Join our platform to manage your account and access dashboards.</p>
    </div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="row g-2">
            <div class="col-6">
                <input asp-for="Input.FirstName" class="form-control" placeholder="First Name">
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            <div class="col-6">
                <input asp-for="Input.LastName" class="form-control" placeholder="Last Name">
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-2">
            <input asp-for="Input.Email" class="form-control" placeholder="Email">
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mt-2">
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password">
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="mt-2">
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password">
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="mt-2">
            <select asp-for="Input.Role" class="form-control">
                <option value="">Select Role</option>
                <option value="User">User</option>
                <option value="Admin">Admin</option>
            </select>
            <span asp-validation-for="Input.Role" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-register w-100 mt-3">Create Account</button>

    </form>

    <div class="extra-links">
        <p>Already have an account? <a asp-page="./Login">Login here</a></p>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}