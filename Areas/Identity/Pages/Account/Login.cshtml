@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}
<link rel="stylesheet" href="dist/css/adminlte.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body {
        margin: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Source Sans Pro", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background-color: #f4f6f9;
    }

    .login-container {
        width: 100%;
        max-width: 950px;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .login-left {
        background: linear-gradient(135deg, #6ea8fe, #a6c8ff);
        color: white;
        padding: 60px 40px;
    }

    .login-left h2 {
        font-weight: 600;
    }

    .login-right {
        padding: 50px;
        background-color: #212529;
        color: white;
    }

    .login-right h3 {
        color: white;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 500;
        color: white;
    }

    .form-control {
        border-radius: 6px;
        border: 1px solid #ced4da;
        padding: 10px 12px;
        font-size: 1rem;
        color: #495057;
        background-color: #fff;
    }

    .form-control:focus {
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
    }

    .btn-login {
        background-color: #80bdff;
        border-color: #80bdff;
        color: #fff;
        font-weight: 500;
        border-radius: 6px;
    }

    .btn-login:hover {
        background-color: #80bdff;
        border-color: #80bdff;
    }

    .form-check-label {
        color: #212529;
    }

    .extra-links {
        font-size: 14px;
    }

    .extra-links a {
        color: #007bff;
        text-decoration: none;
    }

    .extra-links a:hover {
        text-decoration: underline;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    /* PASSWORD EYE STYLE */
    .password-wrapper {
        position: relative;
    }

    .toggle-password {
        position: absolute;
        top: 50%;
        right: 12px;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
    }

    .toggle-password:hover {
        color: #000;
    }
</style>

<div class="login-container">
    <div class="row g-0">

        <!-- LEFT SIDE -->
        <div class="col-md-5 login-left">
            <h2>Welcome Back 👋</h2>
            <p class="mt-3">
                Sign in to access your dashboard, manage your account,
                and explore all features of the system.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-7 login-right">

            <h3 class="mb-4">Login to your account</h3>

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="Enter your email">
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- PASSWORD WITH EYE -->
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>

                    <div class="password-wrapper">
                        <input asp-for="Input.Password" type="password" class="form-control" id="passwordField" placeholder="Enter password">
                        <i class="fa-solid fa-eye toggle-password" id="togglePassword"></i>
                    </div>

                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe">
                    <label class="form-check-label" asp-for="Input.RememberMe">
                        Remember Me
                    </label>
                </div>

                <button type="submit" class="btn btn-login w-100 py-2">
                    Login
                </button>

                <div class="extra-links mt-3">
                    <p>
                        <a asp-page="./ForgotPassword">Forgot Password?</a>
                    </p>

                    <p>
                        Don't have an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
                    </p>
                </div>

            </form>

        </div>
    </div>
</div>

<script src="dist/js/demo.js"></script>

<script>
    const togglePassword = document.querySelector('#togglePassword');
    const passwordField = document.querySelector('#passwordField');

    togglePassword.addEventListener('click', function () {
        const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordField.setAttribute('type', type);

        this.classList.toggle('fa-eye');
        this.classList.toggle('fa-eye-slash');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}