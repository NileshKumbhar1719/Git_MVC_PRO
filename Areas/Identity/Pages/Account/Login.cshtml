@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>

    body {
        background: #f4f7fc;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, sans-serif;
    }

    .login-container {
        width: 100%;
        max-width: 950px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .login-left {
        background: linear-gradient(120deg,#6ea8fe,#a6c8ff);
        color: white;
        padding: 60px 40px;
    }

        .login-left h2 {
            font-weight: 600;
        }

    .login-right {
        padding: 50px;
    }

    .btn-login {
        background: #6ea8fe;
        border: none;
    }

        .btn-login:hover {
            background: #4f8df5;
        }

    .form-control {
        border-radius: 8px;
    }

    .extra-links {
        font-size: 14px;
    }

        .extra-links a {
            text-decoration: none;
        }

    
    }
</style>

<div class="login-container">

    <div class="row g-0">

        <!-- LEFT SIDE -->
        <div class="col-md-5 login-left">

            <h2>Welcome Back 👋</h2>

            <p class="mt-3">
                Sign in to access your dashboard, manage your account,
                and explore all features of the system.
            </p>

        </div>


        <!-- RIGHT SIDE -->
        <div class="col-md-7 login-right">

            <h3 class="mb-4">Login to your account</h3>

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="Enter your email">
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Enter password">
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe">
                    <label class="form-check-label" asp-for="Input.RememberMe">
                        Remember Me
                    </label>
                </div>

                <button type="submit" class="btn btn-login w-100 py-2">
                    Login
                </button>

                <div class="extra-links mt-3">

                    <p>
                        <a asp-page="./ForgotPassword">Forgot Password?</a>
                    </p>

                    <p>
                        Don't have an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
                    </p>

                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}